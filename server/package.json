    "typeorm": "^0.3.17",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.0",
    "axios": "^1.6.0",
    "stripe": "^14.0.0",
    "dotenv": "^16.3.0",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0",
    "express-rate-limit": "^7.0.0",
